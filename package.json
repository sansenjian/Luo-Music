{
  "name": "luo-music",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "axios": "^1.7.9"
    }
  },
  "description": "LUO Music Player - A beautiful music player for Netease Cloud Music and QQ Music",
  "author": "sansenjian",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:server": "concurrently \"npm run server\" \"vite --mode web\"",
    "dev:electron": "concurrently -k \"npm run server\" \"vite\"",
    "prebuild": "node -e \"const fs=require('fs'); if(fs.existsSync('release/win-unpacked')){console.error('ERROR: release directory contains old build! Run npm run clean first'); process.exit(1)}\"",
    "build": "vite build && npm run copy:preload && electron-builder",
    "build:web": "vite build --mode web",
    "build:electron": "npm run clean && vite build && npm run copy:preload && electron-builder",
    "preview": "vite preview",
    "server": "node server.cjs",
    "start": "npm run dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist dist-electron release .vite node_modules/.vite",
    "clean:all": "npm run clean && rimraf node_modules",
    "copy:preload": "node copy-preload.js",
    "analyze": "vite-bundle-visualizer",
    "audit": "npm audit",
    "check:deps": "ncu",
    "update:deps": "ncu -u",
    "check:unused": "depcheck",
    "analyze:bundle": "vite-bundle-visualizer",
    "analyze:deps": "node scripts/analyze-deps.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@babel/plugin-transform-async-to-generator": "^7.28.6",
    "@babel/register": "^7.28.6",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@koa/router": "^15.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.30.1",
    "@sansenjian/qq-music-api": "^2.1.1",
    "@tanstack/vue-query": "^5.92.9",
    "@vercel/analytics": "^1.6.1",
    "@vueuse/core": "^14.2.1",
    "animejs": "^4.3.6",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "form-data": "^4.0.5",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.2.1",
    "koa-static": "^5.0.0",
    "naive-ui": "^2.43.2",
    "picocolors": "^1.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/animejs": "^3.1.13",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "electron": "^40.x",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "axios": "^1.7.9"
  },
  "build": {
    "appId": "com.sansenjian.luomusic",
    "productName": "luo-music",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "maximum",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "shortcutName": "LUO Music"
    },
    "publish": null
  }
}

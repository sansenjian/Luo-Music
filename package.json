{
  "name": "luo-music",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller",
      "sqlite3",
      "@neteasecloudmusicapienhanced/api",
      "@sansenjian/qq-music-api"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "axios": "^1.7.9"
    }
  },
  "description": "LUO Music Player - A beautiful music player for Netease Cloud Music and QQ Music",
  "author": "sansenjian",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "type": "module",
  "main": "build/electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:server": "concurrently \"pnpm run server\" \"vite --mode web\"",
    "dev:electron": "concurrently -k \"pnpm run server\" \"vite\" \"node scripts/dev/dev-electron-launcher.cjs\"",
    "prebuild": "node -e \"const fs=require('fs'); if(fs.existsSync('out')){console.error('ERROR: out directory exists! Run pnpm run clean first'); process.exit(1)}\"",
    "build": "electron-vite build",
    "build:server": "tsup \"server/index.ts\" --format cjs --out-dir build/server --clean",
    "build:electron-main:esbuild": "esbuild electron/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=build/electron/main.cjs --external:electron --external:electron-log --external:@sentry/electron --external:electron-store --external:@neteasecloudmusicapienhanced/api",
    "build:web": "pnpm run build:server && vite build --mode web",
    "build:electron": "pnpm run clean && pnpm run build:server && electron-vite build && electron-forge make",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "start:electron": "electron-forge start",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "start": "pnpm run dev",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "node scripts/clean-force.js",
    "clean:all": "node scripts/clean-force.js --all",
    "analyze": "vite-bundle-visualizer",
    "audit": "pnpm audit",
    "check:deps": "ncu",
    "update:deps": "ncu -u",
    "check:unused": "depcheck",
    "analyze:bundle": "vite-bundle-visualizer",
    "analyze:deps": "node scripts/utils/analyze-deps.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@babel/plugin-transform-async-to-generator": "^7.28.6",
    "@babel/register": "^7.28.6",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@koa/router": "^15.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.30.1",
    "@sansenjian/qq-music-api": "^2.1.1",
    "@tanstack/vue-query": "^5.92.9",
    "@vercel/analytics": "^1.6.1",
    "@vueuse/core": "^14.2.1",
    "animejs": "^4.3.6",
    "async-kit": "^2.2.4",
    "axios": "^1.7.9",
    "combined-stream": "^1.0.8",
    "date-fns": "^4.1.0",
    "delayed-stream": "^1.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "form-data": "^4.0.5",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.2.1",
    "koa-static": "^5.0.0",
    "mime-db": "^1.54.0",
    "mime-types": "^3.0.2",
    "naive-ui": "^2.43.2",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@playwright/test": "^1.58.2",
    "@types/animejs": "^3.1.13",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.12",
    "@types/deep-eql": "^4.0.2",
    "@types/estree": "^1.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/hast": "^3.0.4",
    "@types/http-cache-semantics": "^4.2.0",
    "@types/katex": "^0.16.8",
    "@types/linkify-it": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/mdurl": "^2.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/responselike": "^1.0.3",
    "@types/unist": "^3.0.3",
    "@types/web-bluetooth": "^0.0.21",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "electron": "40.0.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "overrides": {
    "axios": "^1.7.9"
  },
  "config": {
    "forge": "./forge.config.ts"
  }
}

{
  "name": "luo-music",
  "version": "1.0.0",
  "description": "LUO Music Player - A beautiful music player for Netease Cloud Music and QQ Music",
  "author": "sansenjian",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "type": "module",
  "main": "build/electron/main.cjs",
  "scripts": {
    "guard:configs": "node scripts/ensure-no-shadow-configs.cjs",
    "dev": "npm run dev:server",
    "dev:web": "npm run dev:server",
    "dev:server": "npm run guard:configs && concurrently \"npm run server\" \"vite --mode web\"",
    "dev:electron": "npm run guard:configs && concurrently -k \"vite\" \"node scripts/dev/dev-electron-launcher.cjs\"",
    "build": "npm run guard:configs && electron-vite build --config electron.vite.config.ts",
    "build:web": "npm run guard:configs && npm run build:server && vite build --mode web",
    "build:electron:bundle": "npm run guard:configs && concurrently --success all \"npm run build:server\" \"electron-vite build --config electron.vite.config.ts\"",
    "build:electron": "npm run clean && npm run build:electron:bundle && npm run guard:configs && electron-forge make",
    "build:electron:fast": "npm run build:electron:bundle && npm run guard:configs && npm run make:fast",
    "build:server": "tsup \"server/index.ts\" --format cjs --out-dir build/server --clean",
    "preview": "npm run guard:configs && vite preview",
    "preview:electron": "electron-forge start",
    "server": "tsx server/index.ts",
    "package": "npm run guard:configs && electron-forge package",
    "package:fast": "npm run guard:configs && electron-forge package",
    "make": "npm run guard:configs && electron-forge make",
    "make:fast": "npm run guard:configs && node scripts/run-with-env.cjs LUO_FAST_MAKE=1 -- electron-forge make",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,js}\" \"electron/**/*.ts\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,js}\" \"electron/**/*.ts\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "node scripts/clean-force.js",
    "clean:all": "node scripts/clean-force.js --all",
    "analyze": "vite-bundle-visualizer",
    "analyze:deps": "node scripts/utils/analyze-deps.js",
    "analyze:graph": "node scripts/utils/dependency-graph.js --write docs/dependency-graph.md",
    "check:deps": "ncu",
    "check:unused": "depcheck",
    "audit": "npm audit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "lint:staged": "lint-staged"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@koa/router": "^15.0.0",
    "@neteasecloudmusicapienhanced/api": "^4.30.1",
    "@sansenjian/qq-music-api": "^2.2.10",
    "@sentry/electron": "^7.10.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tanstack/vue-query": "^5.92.9",
    "@vercel/analytics": "^1.6.1",
    "@vueuse/core": "^14.2.1",
    "animejs": "^4.3.6",
    "async-mutex": "^0.5.0",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "encoding": "^0.1.13",
    "form-data": "^4.0.5",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.2.1",
    "koa-static": "^5.0.0",
    "lru-cache": "^11.2.7",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sentry/cli": "^3.3.3",
    "@types/animejs": "^3.1.13",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.12",
    "@types/deep-eql": "^4.0.2",
    "@types/estree": "^1.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/hast": "^3.0.4",
    "@types/http-cache-semantics": "^4.2.0",
    "@types/katex": "^0.16.8",
    "@types/linkify-it": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/mdurl": "^2.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.3.3",
    "@types/responselike": "^1.0.3",
    "@types/unist": "^3.0.3",
    "@types/web-bluetooth": "^0.0.21",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "electron": "40.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "fs-extra": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.1.2",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.59.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22.x"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "axios": "^1.7.9"
  },
  "config": {
    "forge": "./forge.config.ts"
  }
}

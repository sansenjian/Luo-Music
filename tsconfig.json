{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@plugin-sdk": ["packages/plugin-sdk/index.ts"],
      "@plugin-sdk/*": ["packages/plugin-sdk/*"],
      "@shared": ["packages/shared/index.ts"],
      "@shared/*": ["packages/shared/*"],
      "@electron/sandbox": ["electron/sandbox/index.ts"]
    },
    "allowJs": false,
    "checkJs": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "api/**/*.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/config/**/*.js",
    "packages/plugin-sdk/**/*.ts",
    "packages/shared/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.d.ts",
    "electron/sandbox/**/*.ts"
  ],
  "exclude": ["electron/main/**/*.ts", "electron/**/*.js"]
}

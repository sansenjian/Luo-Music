# npm registry
registry=https://registry.npmmirror.com
fetch-timeout=600000
fetch-retries=3
fetch-retry-factor=2

# pnpm 配置：使用 hoisted 模式（类似 npm/yarn 的依赖提升）
shamefully-hoist=true
strict-peer-dependencies=false
node-linker=hoisted

# Electron 打包依赖提升（确保 axios 相关依赖被正确打包）
public-hoist-pattern[]=asynckit
public-hoist-pattern[]=form-data
public-hoist-pattern[]=combined-stream
public-hoist-pattern[]=delayed-stream
public-hoist-pattern[]=es-set-tostringtag
public-hoist-pattern[]=es-object-atoms
public-hoist-pattern[]=hasown
public-hoist-pattern[]=function-bind
public-hoist-pattern[]=get-intrinsic
public-hoist-pattern[]=has-symbols
public-hoist-pattern[]=follow-redirects
public-hoist-pattern[]=proxy-from-env
public-hoist-pattern[]=mime-types
public-hoist-pattern[]=mime-db

# Electron 下载配置（使用 GitHub 官方地址以确保 checksum 兼容）
# 注意：如需使用镜像，请确保镜像提供兼容的 SHASUMS256.txt 文件
electron_mirror=https://github.com/electron/electron/releases/download/
electron_cache_dir=./.electron_cache
# 字体镜像
@fontsource/noto-sans-sc:registry=https://registry.npmmirror.com

# 作用域包镜像
@sansenjian:registry=https://registry.npmmirror.com

# JSR registry
@jsr:registry=https://registry.npmmirror.com
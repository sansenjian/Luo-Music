# npm registry: prefer official metadata and fresh resolution by default.
registry=https://registry.npmjs.org
prefer-online=true
prefer-offline=false
replace-registry-host=npmjs
fetch-timeout=600000
fetch-retries=3
fetch-retry-factor=2
# 让 npm lifecycle scripts（例如 electron/install.js）复用系统证书库，
# 解决 Windows 上 `unable to verify the first certificate` 的安装失败。
node-options=--use-system-ca

# Electron 下载默认仍走官方源；如果当前网络访问 GitHub 不稳定，
# 请按 docs/guide/install-troubleshooting.md 中的说明临时设置 ELECTRON_MIRROR。
# 注意：如需使用镜像，请确保镜像提供兼容的 SHASUMS256.txt 文件。

# 字体镜像
@fontsource/noto-sans-sc:registry=https://registry.npmmirror.com

# 项目作用域包使用官方 npm registry，避免镜像旧元数据影响版本解析。
@sansenjian:registry=https://registry.npmjs.org

# JSR 兼容包同样从官方 npm registry 解析。
@jsr:registry=https://registry.npmjs.org

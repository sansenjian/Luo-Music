{
  "manifestVersion": 1,
  "id": "com.luomusic.plugin.qq",
  "name": "QQ Music",
  "version": "1.0.5",
  "description": "QQ 音乐第三方插件，提供搜索、播放、歌词等功能。需要搭配 QQMusicApi 服务端。",
  "author": "Luo-Music",
  "category": "api",
  "platformId": "qq",
  "source": "external",
  "runtime": "external-host",
  "entry": {
    "main": "index.mjs",
    "module": "esm"
  },
  "engines": {
    "pluginApi": "^1.0.0",
    "app": ">=2.3.0"
  },
  "capabilities": {
    "search": true,
    "songUrl": true,
    "songDetail": true,
    "lyric": true,
    "playlistDetail": false,
    "needsHydration": false,
    "supportsLyricFetch": true,
    "supportsUrlRefreshOnFailure": false,
    "auth": {
      "login": true,
      "logout": true,
      "refresh": true,
      "profile": true,
      "importSession": true,
      "preferredMode": "qr",
      "modes": ["qr"]
    },
    "account": {
      "profile": true
    }
  },
  "capabilitiesV2": {
    "music": {
      "search": true,
      "songUrl": true,
      "songDetail": true,
      "lyric": true,
      "playlistDetail": false,
      "urlRefresh": false
    },
    "auth": {
      "login": true,
      "logout": true,
      "refresh": true,
      "profile": true,
      "importSession": true,
      "preferredMode": "qr",
      "modes": ["qr"]
    },
    "account": {
      "profile": true
    },
    "storage": true,
    "network": {
      "domains": [
        "localhost",
        "127.0.0.1",
        "y.gtimg.cn",
        "c.y.qq.com",
        "u.y.qq.com",
        "shc.y.qq.com"
      ]
    },
    "secrets": true
  },
  "permissions": {
    "network": {
      "domains": [
        "localhost",
        "127.0.0.1",
        "y.gtimg.cn",
        "c.y.qq.com",
        "u.y.qq.com",
        "shc.y.qq.com"
      ]
    },
    "storage": true,
    "secrets": true
  },
  "contributions": {
    "settings": [
      {
        "key": "apiBase",
        "type": "text",
        "label": "API 服务地址",
        "default": "http://127.0.0.1:3200"
      },
      {
        "key": "verboseLog",
        "type": "boolean",
        "label": "详细日志",
        "default": false
      }
    ]
  },
  "contributionsV2": [
    {
      "type": "settings",
      "settings": [
        {
          "key": "apiBase",
          "type": "text",
          "label": "API 服务地址",
          "default": "http://127.0.0.1:3200"
        },
        {
          "key": "verboseLog",
          "type": "boolean",
          "label": "详细日志",
          "default": false
        }
      ]
    },
    {
      "type": "auth",
      "preferredMode": "qr",
      "modes": ["qr"]
    }
  ]
}

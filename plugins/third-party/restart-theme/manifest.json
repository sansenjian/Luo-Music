{
  "manifestVersion": 1,
  "id": "com.luomusic.theme.restart",
  "name": "Re:Start Theme",
  "version": "1.0.0",
  "description": "A third-party theme pack inspired by the Re:Start orange-white music player style.",
  "author": "Luo-Music Community",
  "category": "theme",
  "platformId": "restart-theme",
  "source": "external",
  "runtime": "external-host",
  "entry": {
    "main": "index.mjs",
    "module": "esm"
  },
  "engines": {
    "pluginApi": "^1.0.0",
    "app": ">=2.3.0"
  },
  "capabilities": {
    "search": false,
    "songUrl": false,
    "songDetail": false,
    "lyric": false,
    "playlistDetail": false,
    "needsHydration": false,
    "supportsLyricFetch": false,
    "supportsUrlRefreshOnFailure": false
  },
  "permissions": {
    "network": {
      "domains": []
    },
    "storage": false,
    "secrets": false
  },
  "contributions": {
    "themeResources": [
      {
        "id": "com.luomusic.theme.restart.orange-white",
        "label": "Re:Start Orange White",
        "renderStyle": "third-party.restart",
        "description": "Clean white glass panels, restrained graphite text, rounded navigation shells, lyric focus markers, and orange playback accents.",
        "cssVariables": {
          "--bg": "#f6f5f2",
          "--bg-dark": "#ece9e4",
          "--white": "#ffffff",
          "--black": "#1f1f1f",
          "--gray": "#767676",
          "--gray-light": "#b8b4ad",
          "--accent": "#ff5a1f",
          "--accent-hover": "#e84c14",
          "--accent-light": "#ffb28d",
          "--ui-app-bg": "linear-gradient(180deg, #fafafa 0%, #f7f6f2 52%, #ffffff 100%)",
          "--ui-panel-bg": "rgba(255, 255, 255, 0.82)",
          "--ui-surface": "rgba(255, 255, 255, 0.94)",
          "--ui-surface-soft": "rgba(255, 255, 255, 0.86)",
          "--ui-surface-muted": "rgba(31, 31, 31, 0.045)",
          "--ui-control-bg": "rgba(255, 255, 255, 0.88)",
          "--ui-control-focus-bg": "#ffffff",
          "--ui-border-color": "rgba(31, 31, 31, 0.1)",
          "--ui-border-subtle": "rgba(31, 31, 31, 0.07)",
          "--ui-border": "1px solid rgba(31, 31, 31, 0.1)",
          "--ui-border-strong": "1px solid rgba(31, 31, 31, 0.12)",
          "--ui-divider": "1px solid rgba(31, 31, 31, 0.07)",
          "--ui-radius-sm": "8px",
          "--ui-radius-md": "14px",
          "--ui-radius-lg": "20px",
          "--ui-control-radius": "14px",
          "--ui-card-radius": "18px",
          "--ui-shadow": "0 18px 42px rgba(31, 31, 31, 0.08)",
          "--ui-floating-shadow": "0 24px 70px rgba(31, 31, 31, 0.12)",
          "--ui-overlay-bg": "rgba(31, 31, 31, 0.34)",
          "--ui-primary-bg": "#1f1f1f",
          "--ui-primary-text": "#ffffff",
          "--ui-primary-hover-bg": "#2d2d2d",
          "--ui-primary-hover-text": "#ffffff",
          "--ui-primary-shadow": "0 14px 28px rgba(31, 31, 31, 0.16)",
          "--ui-hover-bg": "rgba(255, 90, 31, 0.08)",
          "--ui-track-bg": "rgba(31, 31, 31, 0.14)",
          "--ui-track-fill": "#ff5a1f",
          "--ui-focus-border": "#ff5a1f",
          "--ui-corner-display": "none",
          "--brand-gradient-start": "#ff6b2b",
          "--brand-gradient-end": "#ff4f18",
          "--brand-shadow": "0 10px 24px rgba(255, 90, 31, 0.2)",
          "--brand-kicker-color": "#ff5a1f",
          "--brand-mark-radius": "8px",
          "--home-search-grid-columns": "minmax(0, 1fr)",
          "--home-search-gap": "0",
          "--home-search-width": "min(52vw, 560px)",
          "--home-search-max-width": "560px",
          "--home-search-server-display": "none",
          "--home-search-action-display": "none",
          "--home-search-input-height": "48px",
          "--home-search-input-gap": "14px",
          "--home-search-shell-padding": "0 14px 0 16px",
          "--home-search-shell-border": "1px solid rgba(31, 31, 31, 0.1)",
          "--home-search-shell-radius": "12px",
          "--home-search-shell-bg": "rgba(255, 255, 255, 0.78)",
          "--home-search-shell-shadow": "inset 0 1px 0 rgba(255, 255, 255, 0.7)",
          "--home-search-icon-display": "flex",
          "--home-search-icon-size": "23px",
          "--home-search-icon-color": "#3d3d3d",
          "--home-search-input-padding": "0",
          "--home-search-input-border": "0",
          "--home-search-input-bg": "transparent",
          "--home-search-input-radius": "0",
          "--home-search-input-font-size": "17px",
          "--home-search-input-text": "#222222",
          "--home-search-placeholder-text": "#6d6d6d",
          "--home-search-focus-bg": "transparent",
          "--home-search-focus-border-color": "transparent",
          "--home-search-shortcut-display": "inline-flex",
          "--home-search-shortcut-min-width": "58px",
          "--home-search-shortcut-height": "30px",
          "--home-search-shortcut-padding": "0 12px",
          "--home-search-shortcut-border": "1px solid rgba(31, 31, 31, 0.08)",
          "--home-search-shortcut-radius": "8px",
          "--home-search-shortcut-bg": "rgba(255, 255, 255, 0.62)",
          "--home-search-shortcut-text": "#5f5f5f",
          "--home-search-shortcut-shadow": "0 4px 12px rgba(31, 31, 31, 0.04)",
          "--home-search-shortcut-font-size": "13px",
          "--home-search-shortcut-font-weight": "600",
          "--titlebar-margin": "8px 8px 0",
          "--titlebar-bg": "rgba(255, 255, 255, 0.86)",
          "--titlebar-border": "1px solid rgba(31, 31, 31, 0.1)",
          "--titlebar-divider": "1px solid rgba(31, 31, 31, 0.08)",
          "--titlebar-radius": "20px",
          "--titlebar-shadow": "0 16px 38px rgba(31, 31, 31, 0.08)",
          "--left-panel-margin": "10px 0 10px 10px",
          "--left-panel-bg": "rgba(255, 255, 255, 0.88)",
          "--left-panel-border": "1px solid rgba(31, 31, 31, 0.09)",
          "--left-panel-divider": "1px solid rgba(31, 31, 31, 0.08)",
          "--left-panel-radius": "20px",
          "--left-panel-shadow": "0 20px 48px rgba(31, 31, 31, 0.08)",
          "--workspace-panel-margin": "10px",
          "--workspace-panel-bg": "rgba(255, 255, 255, 0.82)",
          "--workspace-panel-border": "1px solid rgba(31, 31, 31, 0.08)",
          "--workspace-panel-radius": "20px",
          "--workspace-panel-shadow": "0 20px 48px rgba(31, 31, 31, 0.07)",
          "--sidebar-shell-margin": "10px 0 10px 10px",
          "--sidebar-shell-bg": "rgba(255, 255, 255, 0.88)",
          "--sidebar-shell-border": "1px solid rgba(31, 31, 31, 0.09)",
          "--sidebar-shell-divider": "1px solid rgba(31, 31, 31, 0.08)",
          "--sidebar-shell-radius": "20px",
          "--sidebar-shell-shadow": "0 18px 44px rgba(31, 31, 31, 0.08)",
          "--sidebar-shell-glow": "rgba(255, 90, 31, 0.05)",
          "--sidebar-note-border": "rgba(31, 31, 31, 0.07)",
          "--sidebar-note-bg": "rgba(255, 90, 31, 0.08)",
          "--sidebar-note-text": "#ff5a1f",
          "--sidebar-active-bg": "rgba(31, 31, 31, 0.06)",
          "--sidebar-active-text": "#ff5a1f",
          "--sidebar-active-shadow": "inset 0 0 0 1px rgba(31, 31, 31, 0.03)",
          "--sidebar-link-hover-bg": "rgba(31, 31, 31, 0.04)",
          "--sidebar-link-radius": "18px",
          "--sidebar-card-active-border": "rgba(255, 90, 31, 0.34)",
          "--surface-soft": "rgba(255, 255, 255, 0.86)",
          "--surface-muted": "rgba(31, 31, 31, 0.045)",
          "--tabbar-divider": "0",
          "--tab-border": "0",
          "--tab-bg": "transparent",
          "--tab-text": "#6d6d6d",
          "--tab-active-bg": "transparent",
          "--tab-active-text": "#222222",
          "--tab-active-shadow": "none",
          "--tab-active-indicator-display": "block",
          "--tab-active-indicator-inset": "20px",
          "--tab-active-indicator-height": "2px",
          "--tab-active-indicator-color": "#ff5a1f",
          "--lyric-line-gap": "22px",
          "--lyric-line-padding": "8px 0 8px 28px",
          "--lyric-line-radius": "0",
          "--lyric-idle-opacity": "0.64",
          "--lyric-passed-opacity": "0.5",
          "--lyric-active-bg": "transparent",
          "--lyric-active-text": "#222222",
          "--lyric-active-main-text": "#111111",
          "--lyric-active-sub-text": "#111111",
          "--lyric-active-sub-opacity": "1",
          "--lyric-active-border-color": "#ff5a1f",
          "--lyric-active-border-width": "5px",
          "--lyric-active-weight": "800",
          "--lyric-active-shadow": "none",
          "--lyric-roma-size": "15px",
          "--lyric-main-size": "20px",
          "--lyric-main-weight": "400",
          "--lyric-trans-size": "15px",
          "--lyric-roma-text": "#707070",
          "--lyric-trans-text": "#707070"
        },
        "cssText": ":root[data-render-style='third-party.restart'] [data-ui='player']:not(.is-docked) {\n  justify-content: flex-start;\n  padding-top: 22px;\n}\n\n:root[data-render-style='third-party.restart'] .cover-frame {\n  transform: rotate(-1.5deg);\n}\n\n:root[data-render-style='third-party.restart'] .cover-swipe-area:hover .cover-frame {\n  transform: rotate(-1.5deg) scale(1.03);\n}\n\n:root[data-render-style='third-party.restart'] .track-title {\n  font-weight: 900;\n  letter-spacing: 0;\n}\n\n:root[data-render-style='third-party.restart'] .ctrl-main {\n  background: #1f1f1f;\n  color: #ffffff;\n}\n\n:root[data-render-style='third-party.restart'] [data-ui='workspace-panel']::before {\n  content: '';\n  flex: 0 0 auto;\n  height: 3px;\n  background: linear-gradient(90deg, transparent, #ff5a1f, transparent);\n  opacity: 0.75;\n}"
      }
    ]
  }
}

{
  "compilerOptions": {
    "target": "ES2020",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "types": ["node", "electron"],
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@plugin-sdk": ["packages/plugin-sdk/index.ts"],
      "@plugin-sdk/*": ["packages/plugin-sdk/*"],
      "@shared": ["packages/shared/index.ts"],
      "@shared/*": ["packages/shared/*"]
    }
  },
  "include": [
    ".config/**/*.ts",
    "vite.config.ts",
    "config/**/*.ts",
    "config/**/*.d.ts",
    "server/**/*.ts",
    "server/**/*.d.ts",
    "packages/plugin-sdk/**/*.ts",
    "packages/shared/**/*.ts",
    "electron/**/*.js",
    "electron/**/*.ts",
    "electron/**/*.d.ts",
    "src/config/**/*.js",
    "src/config/**/*.d.ts"
  ]
}

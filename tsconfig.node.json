{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "types": ["node", "electron"]
  },
  "include": [
    "vite.config.js",
    "electron/**/*.js",
    "electron/**/*.ts",
    "src/config/**/*.js"
  ]
}

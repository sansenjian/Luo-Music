{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "devCommand": "npm run dev:web",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/qq-api",
      "destination": "/api/qq"
    },
    {
      "source": "/qq-api/:path*",
      "destination": "/api/qq/:path*"
    }
  ],
  "env": {
    "NODE_VERSION": "24"
  }
}
